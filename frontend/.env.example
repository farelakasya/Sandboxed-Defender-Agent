# Sandboxed Defender — SERVER-ONLY config.
# Do NOT prefix secrets with NEXT_PUBLIC_ (that would leak them to the browser).
# Only NEXT_PUBLIC_APP_BASE_URL may be public.
# Copy this file to .env.local and fill in real values for `external` mode.

# ── App base URL (PUBLIC — used to build agent callback URLs) ──────────────
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3001

# ── Detection ticket backend (PUBLIC — no secrets) ─────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://54.84.126.64:8001
# false = use real backend when reachable; true = local mock/Zustand data
NEXT_PUBLIC_USE_MOCK_DATA=false

# ── Unified testing-agent launcher (/api/testing/launch) ───────────────────
# mock | external   (mock needs no external backend)
TESTING_AGENT_MODE=mock
# Collaborator backend that runs the attack/fraud agents (server-only):
TESTING_AGENT_BACKEND_URL=
# Optional shared bearer key for the collaborator backend (server-only):
TESTING_AGENT_API_KEY=

# ── Detection ingestion (/api/detection/events) ────────────────────────────
DETECTION_MODE=mock

# ── Lambda Claude red-team scan proxy (/api/redteam/scan) ──────────────────
# mock | external   (start with mock; no AWS needed)
REDTEAM_SCAN_MODE=mock
# The collaborator's Lambda Function URL (AWS_IAM auth, SigV4-signed by the proxy)
LAMBDA_FUNCTION_URL=https://n23oucit2pdvxg4uqfnktj4dia0gield.lambda-url.us-east-1.on.aws/
# Proxy timeout (ms). 10 Claude agents can take several minutes.
REDTEAM_SCAN_TIMEOUT_MS=300000

# ── AWS credentials — REQUIRED only when REDTEAM_SCAN_MODE=external ─────────
# Keep these server-side only. NEVER commit real values.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Only needed for temporary credentials (STS / SSO):
AWS_SESSION_TOKEN=
