# Red-team scan proxy — SERVER-ONLY config.
# Do NOT prefix any of these with NEXT_PUBLIC_ (that would leak them to the browser).
# Copy this file to .env.local and fill in real values for `external` mode.

# mock | external   (start with mock; no AWS needed)
REDTEAM_SCAN_MODE=mock

# Region of the deployed Lambda
AWS_REGION=us-east-1

# The collaborator's Lambda Function URL (AWS_IAM auth, SigV4-signed by the proxy)
LAMBDA_FUNCTION_URL=https://n23oucit2pdvxg4uqfnktj4dia0gield.lambda-url.us-east-1.on.aws/

# Proxy timeout (ms). 10 Claude agents can take several minutes.
REDTEAM_SCAN_TIMEOUT_MS=300000

# AWS credentials — REQUIRED only when REDTEAM_SCAN_MODE=external.
# Keep these server-side only. NEVER commit real values.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Only needed if you use temporary credentials (STS / SSO):
AWS_SESSION_TOKEN=
