# Sandboxed Defender — SERVER-ONLY config.
# Do NOT prefix secrets with NEXT_PUBLIC_ (that would leak them to the browser).
# Only NEXT_PUBLIC_APP_BASE_URL may be public.
# Copy this file to .env.local and fill in real values for `external` mode.

# ── App base URL (PUBLIC — used to build agent callback URLs) ──────────────
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3001

# ── Defender backend (source of truth) ─────────────────────────────────────
#
# Backend mode (default — recommended for deploys):
#   NEXT_PUBLIC_USE_MOCK_DATA=false
#   DEFENDER_BACKEND_URL=http://54.84.126.64:8001
#
# Mock mode (no backend needed, local Zustand demo data):
#   NEXT_PUBLIC_USE_MOCK_DATA=true
#
# false = use the real defender backend; true = local mock/Zustand data.
NEXT_PUBLIC_USE_MOCK_DATA=false

# Server-only URL the /api/defender/* proxy forwards to. The browser calls the
# same-origin proxy, NOT this URL directly — so HTTPS deploys stay mixed-content
# safe. Not a secret (public service URL), but kept server-side by convention.
DEFENDER_BACKEND_URL=http://54.84.126.64:8001

# Optional PUBLIC override: when set, browser services hit the backend directly
# (handy for local debugging). Leave unset on deploys to use the proxy.
NEXT_PUBLIC_DEFENDER_API_BASE_URL=http://54.84.126.64:8001

# Legacy alias (still read as a fallback). Prefer NEXT_PUBLIC_DEFENDER_API_BASE_URL.
NEXT_PUBLIC_API_BASE_URL=http://54.84.126.64:8001

# ── Attacker-app launcher (/api/testing/launch) ────────────────────────────
# The browser ONLY calls /api/testing/launch. This route forwards server-side
# to the teammate's attacker app, adding the API key. The browser NEVER calls
# the attacker app directly, and the API key is NEVER a NEXT_PUBLIC_ var.
#
# mock     → returns a mock attacker report immediately (no attacker app needed)
# external → forwards the launch to ATTACKER_APP_BASE_URL/<launch path>
TESTING_AGENT_MODE=mock
# Attacker app base URL the proxy forwards to (server-only). For AWS API Gateway
# include the stage, e.g. https://xxxx.execute-api.us-east-1.amazonaws.com/prod
ATTACKER_APP_BASE_URL=
# Launch path appended to the base (default /launch). If the backend returns 404,
# update this to the path the teammate confirms.
ATTACKER_APP_LAUNCH_PATH=/launch
# API key (server-only, NEVER NEXT_PUBLIC_, never logged):
ATTACKER_APP_API_KEY=
# Auth header style: x-api-key (default, AWS API Gateway) | bearer
ATTACKER_APP_AUTH_HEADER=x-api-key
# Legacy aliases (still read as a fallback if the ATTACKER_APP_* vars are unset):
TESTING_AGENT_BACKEND_URL=
TESTING_AGENT_API_KEY=

# ── Detection ingestion (/api/detection/events) ────────────────────────────
DETECTION_MODE=mock

# ── Lambda Claude red-team scan proxy (/api/redteam/scan) ──────────────────
# mock | external   (start with mock; no AWS needed)
REDTEAM_SCAN_MODE=mock
# The collaborator's Lambda Function URL (AWS_IAM auth, SigV4-signed by the proxy)
LAMBDA_FUNCTION_URL=https://n23oucit2pdvxg4uqfnktj4dia0gield.lambda-url.us-east-1.on.aws/
# Proxy timeout (ms). 10 Claude agents can take several minutes.
REDTEAM_SCAN_TIMEOUT_MS=300000

# ── AWS credentials — REQUIRED only when REDTEAM_SCAN_MODE=external ─────────
# Keep these server-side only. NEVER commit real values.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Only needed for temporary credentials (STS / SSO):
AWS_SESSION_TOKEN=
